# ── Azure OpenAI (required for classification) ───────────────
# Endpoint looks like: https://<your-resource>.openai.azure.com/
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2025-04-01-preview
# Name of YOUR deployment (not the model id) — e.g. gpt-4o-mini
AZURE_OPENAI_DEPLOYMENT=gpt-5.4

# ── Database ─────────────────────────────────────────────────
# Dev default is a local SQLite file. For production point this at
# Azure PostgreSQL: postgresql+psycopg://user:pass@host:5432/vorentice
DATABASE_URL=sqlite:///./vorentice_news.db

# ── Agent behaviour ──────────────────────────────────────────
# Max articles sent to the LLM per run (cost guard)
NEWS_MAX_LLM_ARTICLES=60
# Minutes between scheduled agent runs
NEWS_RUN_INTERVAL_MINUTES=30
# Set true to run the pipeline WITHOUT calling the LLM (heuristic
# classification only) — useful for testing ingestion with no keys.
NEWS_DRY_RUN=false

# ══════════════════════════════════════════════════════════════════
#  NEWS AGENT — EXTERNAL DATA SOURCES
#  Keyless sources need nothing here (already active). For the rest,
#  make a free account at the URL shown and paste the key after '='.
#  A blank key keeps that source DORMANT — the pipeline skips it
#  cleanly, so nothing breaks while you register.
# ══════════════════════════════════════════════════════════════════

# ── KEYLESS — no account, already active ──────────────────────────
#   GDELT DOC 2.0     global news firehose      (article)
#   ISW / CSIS        think-tank analysis (RSS) (article)
#   ReliefWeb         UN disaster/humanitarian  (article)
#   Open-Meteo        global weather + marine   (signal)
#   NOAA NWS          live weather (US waters)  (signal)
#   ECMWF Open-Data   global forecast model     (signal)
# ReliefWeb only asks callers to identify themselves — any string, no signup:
RELIEFWEB_APPNAME=vorentice-news-agent

# ── EIA — U.S. Energy Information Administration ───────────────────
#   Crude inventories, spot prices, production, import volumes.
#   FREE · instant · https://www.eia.gov/opendata/register.php
EIA_API_KEY=

# ── FRED — Federal Reserve Bank of St. Louis ──────────────────────
#   Oil price indices, macro/economic series.
#   FREE · instant · https://fredaccount.stlouisfed.org/apikeys
FRED_API_KEY=

# ── OpenSanctions — sanctioned entities / vessels / tankers ───────
#   Free tier with rate limits; key raises the limit.
#   https://www.opensanctions.org/api/  (OPTIONAL — works keyless too)
OPENSANCTIONS_API_KEY=

# ── ACLED — armed-conflict event data ─────────────────────────────
#   FREE · email approval ~1 day · https://developer.acleddata.com/
#   (OPTIONAL — you flagged this as optional)
ACLED_API_KEY=
ACLED_EMAIL=

# ── NOAA Climate Data Online token ────────────────────────────────
#   Only for HISTORICAL climate datasets; live weather above is keyless.
#   FREE · https://www.ncdc.noaa.gov/cdo-web/token  (OPTIONAL)
NOAA_CDO_TOKEN=

SERPER_API_KEY=
